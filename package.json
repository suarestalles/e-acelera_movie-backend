{
  "name": "backend",
  "version": "0.0.0",
  "scripts": {
    "build": "rm -rf dist && npm run lint && tsc --project tsconfig.prod.json",
    "dev:basic": "ts-node ./src/app",
    "dev:watch": "nodemon --exec \"npm run dev:basic\" --watch ./src --ext .ts",
    "dev": "npm run dev:watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "node -r dotenv/config -r module-alias/register ./dist/main.js",
    "test": "cross-env NODE_ENV=test vitest",
    "type-check": "tsc -b --noEmit",
    "typeorm": "typeorm-ts-node-commonjs"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "_moduleAliases": {
    "@src": "dist"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "jet-logger": "^2.2.3",
    "jet-paths": "^3.1.1",
    "jet-validators": "^2.3.1",
    "jsonfile": "^6.2.1",
    "module-alias": "^2.3.4",
    "morgan": "^1.11.0",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.43",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/find": "^0.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonfile": "^6.1.4",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "browser-sync": "^3.0.4",
    "concurrently": "^10.0.3",
    "delay-cli": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.2.2",
    "find": "^0.3.0",
    "fs-extra": "^11.3.6",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.5",
    "shx": "^0.4.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
